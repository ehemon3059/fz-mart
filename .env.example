# ─────────────────────────────────────────────────────────────
# fz-mart environment template — copy to .env and fill in.
# Commit THIS file (.env.example); never commit .env.
# ─────────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────────────
# MySQL-compatible connection string used by Prisma.
# Local:  mysql://USER:PASSWORD@HOST:PORT/DATABASE
# TiDB Cloud Serverless (production/Vercel): copy the connection string from the
# TiDB console and append ?sslaccept=strict for its required TLS, e.g.
#   mysql://xxxx.root:PASSWORD@gateway01.<region>.prod.aws.tidbcloud.com:4000/DBNAME?sslaccept=strict
DATABASE_URL="mysql://root:password@localhost:3306/fz_mart"

# Redis — cache, sessions, IP-block set, and the BullMQ job queue.
# Local:    redis://localhost:6379
# Upstash (production/Vercel): use the rediss:// URL (note the double 's' — TLS).
# The code auto-enables TLS for rediss:// URLs.
#   rediss://default:PASSWORD@<name>.upstash.io:6379
# On Vercel there is NO background worker process, so queued jobs (email, SMS,
# abandoned-cart, maintenance) are never consumed — that's expected. If REDIS_URL
# is unset the app still runs; Redis-backed features (cache, rate limiting,
# sessions) just degrade gracefully.
REDIS_URL="redis://localhost:6379"

# 32-byte key (64 hex chars) for AES-256-GCM encryption of secrets
# stored in the Setting table. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: if this key is lost, every encrypted Setting becomes unreadable.
ENCRYPTION_KEY=""

# Secret for signing/identifying admin sessions. Generate the same way.
SESSION_SECRET=""

# Public base URL of the app (fallback only). The store's live domain is
# normally set in the admin panel at Settings → Appearance → Site URL, which
# overrides this at runtime for feeds, sitemap, canonical/OG URLs and emails.
# This env value is used until a domain is saved there (and for admin
# invite/reset links, which read NEXT_PUBLIC_BASE_URL below).
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Some admin flows (password reset, admin invites) read this alias; set it to
# the same value as NEXT_PUBLIC_APP_URL.
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ── Image hosting: Cloudflare R2 (object storage) ────────────────
# Admin uploads (product/variant/banner images, logo) are stored in R2 so they
# survive redeploys onto an empty local filesystem. Leave these blank in local
# dev and uploads fall back to public/uploads on disk (fine for one dev box,
# never for serverless/production).
#
# Create an R2 bucket, then in the Cloudflare dashboard:
#   • R2 → Manage API Tokens → create an "Object Read & Write" token → gives the
#     Access Key ID and Secret Access Key below.
#   • R2 → your bucket → Settings → enable a public URL (r2.dev) or connect a
#     custom domain → that's R2_PUBLIC_BASE_URL (no trailing slash).
# R2_ACCOUNT_ID is your Cloudflare account id (R2 overview page / endpoint host).
# The bucket must be public-readable for next/image to fetch the stored objects.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_BASE_URL=""

# ── Error reporting (optional, Phase 3) ──────────────────────────
# Sentry is entirely opt-in: leave blank to disable on every runtime.
# Server + worker use SENTRY_DSN; the browser bundle uses the NEXT_PUBLIC one.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_TRACES_SAMPLE_RATE="0.1"

# ── Database backups (scripts/backup.sh, Phase 3) ────────────────
# Only needed on the server that runs the backup cron. DB_PASSWORD may be empty
# for a local socket. RCLONE_REMOTE points at a configured Backblaze B2 remote.
# DB_NAME="fz_mart"
# DB_USER="fzmart"
# DB_PASSWORD=""
# DB_HOST="127.0.0.1"
# DB_PORT="3306"
# BACKUP_DIR="/var/backups/fz-mart"
# RCLONE_REMOTE="b2:fz-mart-backups"
# RETENTION_DAYS="30"
