// fz-mart — Prisma schema
//
// Phase-0 scope: model only what Phase 1 (the storefront vertical slice) needs,
// plus the generic Setting model that many later features depend on.
// Integration models (CourierShipment, SmsLog, MailLog, FraudCheckResult,
// BlockedIp) are added in their own phases — premature schema is rework.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// Catalog
// ─────────────────────────────────────────────────────────────

model Category {
  id            Int           @id @default(autoincrement())
  name          String
  slug          String        @unique
  sortOrder     Int           @default(0)
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  subcategories Subcategory[]

  @@index([isActive, sortOrder])
}

model Subcategory {
  id         Int       @id @default(autoincrement())
  categoryId Int
  name       String
  slug       String    @unique
  sortOrder  Int       @default(0)
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  category   Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  products   Product[]

  @@index([categoryId, isActive, sortOrder])
}

model Product {
  id            Int            @id @default(autoincrement())
  subcategoryId Int
  name          String
  slug          String         @unique
  description   String?        @db.Text
  // price and discountPrice are stored in the smallest currency unit (paisa)
  // as integers to avoid floating-point rounding on money.
  price         Int
  discountPrice Int?
  stock         Int            @default(0)
  isFeatured    Boolean        @default(false)
  status        ProductStatus  @default(ACTIVE)
  promoBadge    String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subcategory   Subcategory    @relation(fields: [subcategoryId], references: [id])
  images        ProductImage[]
  orderItems    OrderItem[]
  flashSales    FlashSaleProduct[]

  @@index([subcategoryId, status])
  @@index([isFeatured, status])
}

enum ProductStatus {
  ACTIVE
  INACTIVE
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  productId Int
  url       String
  isPrimary Boolean @default(false)
  sortOrder Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
}

model Banner {
  id        Int      @id @default(autoincrement())
  imageUrl  String
  link      String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([isActive, sortOrder])
}

// A scheduled campaign with a curated product list. "Active" on the
// storefront means isActive=true AND now is within [startsAt, endsAt] —
// the boolean lets an admin pause a campaign without losing its dates.
model FlashSale {
  id        Int               @id @default(autoincrement())
  name      String
  startsAt  DateTime
  endsAt    DateTime
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  products  FlashSaleProduct[]

  @@index([isActive, startsAt, endsAt])
}

model FlashSaleProduct {
  id          Int       @id @default(autoincrement())
  flashSaleId Int
  productId   Int
  // Optional override price (paisa) for the duration of the sale, distinct
  // from the product's own discountPrice so the same product can carry a
  // deeper, time-boxed cut without permanently changing its catalog price.
  salePrice   Int?
  sortOrder   Int       @default(0)
  flashSale   FlashSale @relation(fields: [flashSaleId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([flashSaleId, productId])
  @@index([flashSaleId, sortOrder])
}

// ─────────────────────────────────────────────────────────────
// Orders
// ─────────────────────────────────────────────────────────────

model Order {
  id             Int         @id @default(autoincrement())
  // Public, short, human-readable identifier for COD phone calls / tracking.
  orderNo        String      @unique
  customerName   String
  customerPhone  String
  // Optional — phone is the primary contact for COD; email is only used to
  // send an order-confirmation mail when the customer provides one.
  customerEmail  String?
  address        String      @db.Text
  shippingZoneId Int?
  deliveryCharge Int         @default(0)
  subtotal       Int
  total          Int
  status         OrderStatus @default(PENDING)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  shippingZone   ShippingZone? @relation(fields: [shippingZoneId], references: [id])
  items          OrderItem[]
  courierShipment CourierShipment?

  @@index([status, createdAt])
  @@index([customerPhone])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

model OrderItem {
  id          Int     @id @default(autoincrement())
  orderId     Int
  productId   Int?
  // SNAPSHOTS — frozen at purchase time. Editing or deleting a product later
  // must never change historical orders, so name + price live on the row.
  productName String
  unitPrice   Int
  quantity    Int
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
}

// ─────────────────────────────────────────────────────────────
// Settings & shipping
// ─────────────────────────────────────────────────────────────

model ShippingZone {
  id        Int      @id @default(autoincrement())
  name      String
  charge    Int      @default(0)
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  orders    Order[]

  @@index([isActive, sortOrder])
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  role         String   @default("admin")
  createdAt    DateTime @default(now())
}

// The DB row is the editable source of truth; middleware enforces against a
// mirrored Redis SET (O(1), no DB hit per request). On add/remove, sync both,
// and rebuild the Redis set from this table on boot so a cache flush can't
// silently unblock everyone.
model BlockedIp {
  id        Int      @id @default(autoincrement())
  ip        String   @unique
  reason    String?
  createdAt DateTime @default(now())
}

// Audit log for every outbound mail attempt — sent via the queue, never
// inline with checkout. One row per attempt (including retries), so a
// failure trail is visible even though the worker retries automatically.
model MailLog {
  id        Int           @id @default(autoincrement())
  to        String
  subject   String
  template  String
  status    NotifyStatus  @default(PENDING)
  error     String?       @db.Text
  createdAt DateTime      @default(now())

  @@index([status, createdAt])
}

// Same auditing role as MailLog, for SMS sends.
model SmsLog {
  id        Int          @id @default(autoincrement())
  to        String
  template  String
  status    NotifyStatus @default(PENDING)
  error     String?      @db.Text
  createdAt DateTime     @default(now())

  @@index([status, createdAt])
}

enum NotifyStatus {
  PENDING
  SENT
  FAILED
}

// One consignment per order. Webhook updates key on consignmentId + status
// so a duplicate callback (providers retry) is a no-op rather than a
// double-write — see the webhook route for the idempotency check.
model CourierShipment {
  id             Int      @id @default(autoincrement())
  orderId        Int      @unique
  courierName    String
  consignmentId  String   @unique
  trackingCode   String?
  courierStatus  String
  lastSyncedAt   DateTime @default(now())
  createdAt      DateTime @default(now())
  order          Order    @relation(fields: [orderId], references: [id])

  @@index([consignmentId])
}

// Cached per phone number — also mirrored in Redis (see lib/fraud-cache.ts)
// since fraud lookups cost money/time per call.
model FraudCheckResult {
  id            Int      @id @default(autoincrement())
  phone         String   @unique
  totalOrders   Int      @default(0)
  successOrders Int      @default(0)
  returnOrders  Int      @default(0)
  riskScore     Int
  checkedAt     DateTime @default(now())
}

// Generic encrypted-capable config store. `group` namespaces keys
// (e.g. "smtp", "courier"); secrets are encrypted at rest via lib/crypto.ts
// and flagged with isEncrypted so the reader knows to decrypt.
model Setting {
  id          Int      @id @default(autoincrement())
  group       String
  key         String
  value       String   @db.Text
  isEncrypted Boolean  @default(false)
  updatedAt   DateTime @updatedAt

  @@unique([group, key])
}

enum PageStatus {
  PUBLISHED
  DRAFT
}

// Fixed set of footer/legal/support pages (About Us, Contact Us, Company
// Information, Terms & Conditions, Privacy Policy, Support Center, How to
// Order, Order Tracking, Payment, Shipping). Slugs are seeded once and never
// created/deleted from the admin UI — admins only edit title/content/status.
model Page {
  id        Int        @id @default(autoincrement())
  slug      String     @unique
  title     String
  content   String     @db.Text
  status    PageStatus @default(PUBLISHED)
  updatedAt DateTime   @updatedAt
}

// FAQ entries shown on the FAQ page. Unlike Page, this is a real list the
// admin can add/remove/reorder, since FAQs are naturally many Q&A pairs
// rather than one block of content.
model FaqItem {
  id        Int      @id @default(autoincrement())
  question  String
  answer    String   @db.Text
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}
