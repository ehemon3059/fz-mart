// fz-mart — Prisma schema
//
// Phase-0 scope: model only what Phase 1 (the storefront vertical slice) needs,
// plus the generic Setting model that many later features depend on.
// Integration models (CourierShipment, SmsLog, MailLog, FraudCheckResult,
// BlockedIp) are added in their own phases — premature schema is rework.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// Catalog
// ─────────────────────────────────────────────────────────────

model Category {
  id              Int           @id @default(autoincrement())
  name            String
  slug            String        @unique
  // Optional hero image + short blurb shown on the storefront category pages.
  imageUrl        String?
  description     String?       @db.Text
  sortOrder       Int           @default(0)
  isActive        Boolean       @default(true)
  // Optional SEO overrides (Phase 2). When blank the storefront falls back to
  // a sensible default derived from the name — see lib/seo.ts.
  metaTitle       String?
  metaDescription String?       @db.Text
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  subcategories   Subcategory[]
  coupons         Coupon[]

  @@index([isActive, sortOrder])
}

model Subcategory {
  id          Int       @id @default(autoincrement())
  categoryId  Int
  name        String
  slug        String    @unique
  // Optional image + short blurb shown on the storefront subcategory listings.
  imageUrl    String?
  description String?   @db.Text
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  category   Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  products   Product[]

  @@index([categoryId, isActive, sortOrder])
}

model Product {
  id                 Int                    @id @default(autoincrement())
  subcategoryId      Int
  name               String
  slug               String                 @unique
  description        String?                @db.Text
  // price and discountPrice are stored in the smallest currency unit (paisa)
  // as integers to avoid floating-point rounding on money.
  price              Int
  discountPrice      Int?
  // Current sourcing/purchase cost per unit (paisa) — what it costs the shop to
  // stock one unit. Feeds COGS: it is SNAPSHOTTED onto OrderItem at checkout so
  // later supplier-price changes never rewrite historical margins.
  purchaseCost       Int                    @default(0)
  stock              Int                    @default(0)
  // Low-stock alert threshold (Phase 5). When 0 < stock <= this, the product
  // surfaces in the admin low-stock alert + daily digest. 0 disables it.
  lowStockThreshold  Int                    @default(0)
  // Whether the "In stock (N available)" count is shown on the storefront for a
  // simple (variant-less) product. Availability (sold-out disabling) is
  // unaffected — this only hides the number. Mirrors ProductVariant.showStock.
  showStock          Boolean                @default(true)
  isFeatured         Boolean                @default(false)
  status             ProductStatus          @default(ACTIVE)
  promoBadge         String?
  // Optional SEO overrides (Phase 2); blank → default from name/description.
  metaTitle          String?
  metaDescription    String?                @db.Text
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  subcategory        Subcategory            @relation(fields: [subcategoryId], references: [id])
  images             ProductImage[]
  orderItems         OrderItem[]
  flashSales         FlashSaleProduct[]
  colors             ProductColor[]
  specifications     ProductSpecification[]
  features           ProductFeature[]
  reviews            ProductReview[]
  variants           ProductVariant[]
  wishlistItems      WishlistItem[]
  stockNotifications StockNotification[]
  stockAdjustments   StockAdjustment[]
  coupons            Coupon[]
  cartItems          CustomerCartItem[]
  cartEvents         CartEvent[]

  @@index([subcategoryId, status])
  @@index([isFeatured, status])
  // Full-text search over name + description. The default parser is
  // whitespace/punctuation based, which handles space-separated Bangla words;
  // querying is via MATCH … AGAINST in server/products/search.ts.
  //
  // TiDB only supports single-column FULLTEXT indexes, so name and description
  // are indexed separately and the search queries MATCH each column on its own
  // (summing the two AGAINST scores for relevance).
  @@fulltext([name])
  @@fulltext([description])
}

// Purchasable option of a product — one cell of the (color × size) matrix.
// Either dimension may be null:
//   • Oil:     size="1 Litre", colorName=null         (size-only)
//   • T-shirt: size="M", colorName="Navy Blue"        (color + size combo)
//   • Color-only good: size=null, colorName="Red"
// When a product has any variants the customer MUST pick one; that variant's
// own price and stock are authoritative (product price becomes a "from" only).
// colorName links to a ProductColor by name, which supplies the swatch image.
model ProductVariant {
  id           Int         @id @default(autoincrement())
  productId    Int
  size         String? // "500 ml", "M", "XL"
  colorName    String? // matches a ProductColor.name for the swatch/image
  price        Int // paisa — authoritative "regular" price for this option
  // Optional sale price (paisa). When set (and below price) it's the amount
  // actually charged; price shows struck-through. Null = no discount.
  discountPrice Int?
  // Per-variant sourcing cost (paisa). 0 = "inherit the product's purchaseCost";
  // checkout falls back to Product.purchaseCost when this is 0.
  purchaseCost Int         @default(0)
  stock        Int         @default(0)
  // Whether the "X in stock" count is shown on the storefront for this variant.
  // Availability (sold-out disabling) is unaffected — this only hides the number.
  showStock    Boolean     @default(true)
  sortOrder    Int         @default(0)
  product      Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems   OrderItem[]

  @@index([productId, sortOrder])
}

enum ProductStatus {
  ACTIVE
  INACTIVE
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  productId Int
  url       String
  isPrimary Boolean @default(false)
  sortOrder Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
}

model ProductColor {
  id        Int     @id @default(autoincrement())
  productId Int
  name      String
  hexCode   String
  imageUrl  String?
  sortOrder Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
}

model ProductSpecification {
  id        Int     @id @default(autoincrement())
  productId Int
  label     String
  value     String
  sortOrder Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
}

model ProductFeature {
  id        Int     @id @default(autoincrement())
  productId Int
  text      String
  sortOrder Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
}

// One review per customer per product — enforced by the unique constraint
// below, so re-submitting overwrites rather than duplicates.
enum ReviewStatus {
  PENDING
  APPROVED
  HIDDEN
}

model ProductReview {
  id         Int          @id @default(autoincrement())
  productId  Int
  customerId String
  rating     Int
  comment    String       @db.Text
  status     ReviewStatus @default(PENDING)
  createdAt  DateTime     @default(now())
  product    Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  customer   Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([productId, customerId])
  @@index([productId, status, createdAt])
}

model Banner {
  id        Int        @id @default(autoincrement())
  imageUrl  String
  link      String?
  // Which hero area this image fills. MAIN is the big left banner (supports
  // several images as a carousel); the RIGHT_* slots are single cards.
  slot      BannerSlot @default(MAIN)
  sortOrder Int        @default(0)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())

  @@index([slot, isActive, sortOrder])
}

enum BannerSlot {
  MAIN
  RIGHT_TOP
  RIGHT_BOTTOM
}

// A scheduled campaign with a curated product list. "Active" on the
// storefront means isActive=true AND now is within [startsAt, endsAt] —
// the boolean lets an admin pause a campaign without losing its dates.
model FlashSale {
  id        Int                @id @default(autoincrement())
  name      String
  startsAt  DateTime
  endsAt    DateTime
  isActive  Boolean            @default(true)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  products  FlashSaleProduct[]

  @@index([isActive, startsAt, endsAt])
}

model FlashSaleProduct {
  id          Int       @id @default(autoincrement())
  flashSaleId Int
  productId   Int
  // Optional override price (paisa) for the duration of the sale, distinct
  // from the product's own discountPrice so the same product can carry a
  // deeper, time-boxed cut without permanently changing its catalog price.
  salePrice   Int?
  sortOrder   Int       @default(0)
  flashSale   FlashSale @relation(fields: [flashSaleId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([flashSaleId, productId])
  @@index([flashSaleId, sortOrder])
}

// ─────────────────────────────────────────────────────────────
// Customers (passwordless — magic link or Google sign-in, no password)
// ─────────────────────────────────────────────────────────────

enum AuthProvider {
  GOOGLE
  EMAIL
}

model Customer {
  // Custom, human-readable id of the form `fz-XXXXXX` (see lib/customer-id.ts).
  // Generated in application code, so no @default here.
  id        String          @id
  email     String          @unique
  name      String?
  avatarUrl String?
  provider  AuthProvider
  createdAt DateTime        @default(now())
  orders    Order[]
  reviews   ProductReview[]
  wishlist  WishlistItem[]
  cart      CustomerCart?
  cartEvents CartEvent[]
}

// Single-use magic-link tokens. usedAt marks consumption (kept for audit
// rather than deleted); expiresAt enforces a short window (e.g. 15 min).
model LoginToken {
  id        Int       @id @default(autoincrement())
  email     String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
}

// ─────────────────────────────────────────────────────────────
// Orders
// ─────────────────────────────────────────────────────────────

model Order {
  id                 Int               @id @default(autoincrement())
  // Public, short, human-readable identifier for COD phone calls / tracking.
  orderNo            String            @unique
  // Nullable — checkout stays guest-friendly; set when the customer was
  // signed in at checkout time, purely to power order history.
  customerId         String?
  customerName       String
  customerPhone      String
  // Optional — phone is the primary contact for COD; email is only used to
  // send an order-confirmation mail when the customer provides one.
  customerEmail      String?
  address            String            @db.Text
  // Optional free-text note from the customer at checkout ("leave at gate",
  // delivery timing, etc.). Distinct from the admin-only `notes` relation.
  customerNote       String?           @db.Text
  shippingZoneId     Int?
  deliveryCharge     Int               @default(0)
  subtotal           Int
  total              Int
  // ── Financial tracking (paisa) — the real costs behind an order, entered by
  // the admin on the order detail page and aggregated by the monthly P&L. These
  // are the shop's OWN costs, distinct from deliveryCharge (what the CUSTOMER
  // pays). Defaults keep historical orders valid; admins fill them in per order.
  //
  //   shippingCost        — outbound courier fee the shop pays to deliver.
  //   returnShippingCost  — courier fee lost when an order comes back.
  //   paymentGatewayFee   — COD collection / mobile-wallet processing fee.
  //   returnRestockable   — for RETURNED orders: true = goods can be resold
  //                         (no cost impact), false = damaged (cost → Inventory
  //                         Loss under OpEx).
  shippingCost       Int               @default(0)
  returnShippingCost Int               @default(0)
  paymentGatewayFee  Int               @default(0)
  returnRestockable  Boolean           @default(true)
  // ── Payment (Phase 1) ──
  //   COD     — full cash on delivery (default, unchanged behaviour).
  //   ONLINE  — full amount paid through a gateway before confirmation.
  //   PARTIAL — delivery charge paid online, remainder COD (the standard BD
  //             anti-fake-order pattern).
  // paidAmount is the paisa actually CONFIRMED online (via IPN + validation),
  // so COD due on delivery = total - paidAmount.
  paymentMethod      PaymentMethod     @default(COD)
  paidAmount         Int               @default(0)
  // ── Coupon (Phase 4) ── snapshotted at checkout so later coupon edits never
  // rewrite a historical order. total already has couponDiscount subtracted.
  couponCode         String?
  couponDiscount     Int               @default(0)
  // ── Facebook attribution (Conversions API) ── click identifiers captured at
  // checkout so a later server-side Purchase event (fired when the owner phone-
  // confirms the order) can be matched back to the ad that drove it. Null when
  // the shopper didn't arrive from a Facebook ad or blocked the pixel cookie.
  //   fbp — the _fbp browser cookie the Pixel sets on every visitor.
  //   fbc — derived from the fbclid URL param on an ad click (fb.1.<ts>.<id>).
  fbp                String?
  fbc                String?
  // ── Marketing attribution (GAP 3) ── first-touch UTM params captured at
  // checkout from a landing cookie, so a delivered order can be classified to a
  // channel for ROAS/CAC even when it carries no Facebook click id (Google,
  // TikTok, etc.). Null for organic/direct visitors.
  utmSource          String?
  utmMedium          String?
  utmCampaign        String?
  status             OrderStatus       @default(PENDING)
  // ── Courier (Phase 3+) ── which provider shipped this order. Set at
  // consignment-creation time and FROZEN thereafter: manual "Refresh Status"
  // and webhook routing always dispatch to THIS provider, never the currently
  // active one — so switching the shop's active courier never misroutes an
  // already-shipped order's status lookups. Null until a consignment exists.
  courierProvider    CourierProvider?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  customer           Customer?         @relation(fields: [customerId], references: [id])
  shippingZone       ShippingZone?     @relation(fields: [shippingZoneId], references: [id])
  items              OrderItem[]
  courierShipment    CourierShipment?
  statusLogs         OrderStatusLog[]
  notes              OrderNote[]
  payments           Payment[]
  returnRequests     ReturnRequest[]
  couponRedemption   CouponRedemption?

  @@index([status, createdAt])
  @@index([customerPhone])
  @@index([customerId])
}

// Courier providers the adapter layer can dispatch to. Stored on Order once a
// consignment is created so status refresh/webhooks route to the right adapter
// regardless of which provider is currently "active" in settings.
enum CourierProvider {
  STEADFAST
  PATHAO
  REDX
}

enum OrderStatus {
  // Online-payment orders start here: stock is already reserved (decremented)
  // but the order is not real until the gateway confirms. Auto-cancelled with
  // stock released if payment doesn't arrive within the expiry window.
  PENDING_PAYMENT
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum PaymentMethod {
  COD
  ONLINE
  PARTIAL
}

enum PaymentStatus {
  INITIATED
  SUCCESS
  FAILED
  REFUNDED
}

// One gateway payment attempt. An order can have several (abandoned attempt,
// then a successful retry), so payments are rows, not columns on Order.
// amount is paisa like all money. rawPayload keeps the provider's verbatim
// IPN/validation response for dispute evidence — never parsed after write.
model Payment {
  id            Int           @id @default(autoincrement())
  orderId       Int
  provider      String // "sslcommerz" | "bkash" | "mock"
  amount        Int
  status        PaymentStatus @default(INITIATED)
  // Provider's transaction/reference id once known (val_id / trxID). The
  // provider's idempotency anchor for IPN retries.
  providerTxnId String?
  rawPayload    Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  order         Order         @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([provider, providerTxnId])
}

model OrderItem {
  id           Int             @id @default(autoincrement())
  orderId      Int
  productId    Int?
  // Which size/option was bought, if the product is sized. variantLabel is a
  // SNAPSHOT (like productName) so historical orders survive a variant edit.
  variantId    Int?
  variantLabel String?
  // SNAPSHOTS — frozen at purchase time. Editing or deleting a product later
  // must never change historical orders, so name + price live on the row.
  productName  String
  unitPrice    Int
  // SNAPSHOT of the sourcing cost per unit (paisa) at purchase time — the COGS
  // basis for this line. Frozen here so a later supplier-price edit on the
  // product never distorts a past month's profit. See createOrder.ts.
  purchaseCost Int             @default(0)
  quantity     Int
  order        Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant      ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([orderId])
}

// Append-only audit trail of every status transition. fromStatus is null for
// the very first (PENDING) entry written at order creation. changedBy holds
// the admin username, or null for system/customer-originated changes.
model OrderStatusLog {
  id         Int          @id @default(autoincrement())
  orderId    Int
  fromStatus OrderStatus?
  toStatus   OrderStatus
  changedBy  String?
  note       String?      @db.Text
  createdAt  DateTime     @default(now())
  order      Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
}

// Internal staff notes on an order (e.g. "called customer, confirmed address").
// Never shown to customers; author is the admin username.
model OrderNote {
  id        Int      @id @default(autoincrement())
  orderId   Int
  body      String   @db.Text
  author    String
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
}

// ─────────────────────────────────────────────────────────────
// Settings & shipping
// ─────────────────────────────────────────────────────────────

model ShippingZone {
  id        Int      @id @default(autoincrement())
  name      String
  charge    Int      @default(0)
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  orders    Order[]

  @@index([isActive, sortOrder])
}

model AdminUser {
  id               Int                  @id @default(autoincrement())
  username         String               @unique
  // Recovery address for password resets. Nullable so pre-existing admins stay
  // valid; a reset can only be requested for an admin that has one set.
  email            String?              @unique
  passwordHash     String
  // RBAC (Phase 3). See lib/permissions.ts for what each role may do. The
  // permission check re-reads role + isActive from this row on every request,
  // so a role change or deactivation takes effect immediately (not on next login).
  role             AdminRole            @default(STAFF)
  // Deactivated admins keep their row (for audit-log attribution) but can't
  // log in or hold a valid session.
  isActive         Boolean              @default(true)
  // Optional TOTP two-factor. Secret is encrypted at rest via lib/crypto.
  twoFactorSecret  String?
  twoFactorEnabled Boolean              @default(false)
  createdAt        DateTime             @default(now())
  resetTokens      PasswordResetToken[]
  activityLogs     AdminActivityLog[]
  backupCodes      AdminBackupCode[]
}

// One-time 2FA recovery codes, for when an admin can't reach their
// authenticator app. Generated 10 at a time (see server/admin/twofactor.ts);
// regenerating deletes the old set so a leaked/lost batch can't be reused.
// Only the bcrypt hash is stored — like passwordHash, the plaintext is shown
// to the admin once at generation time and never persisted.
model AdminBackupCode {
  id        Int       @id @default(autoincrement())
  adminId   Int
  codeHash  String
  // AES-GCM encrypted code value (lib/crypto), so the admin panel can show the
  // plaintext of used codes. Nullable: codes generated before this column
  // existed have only the one-way hash and can't be displayed. Verification
  // always uses codeHash — codeEnc is display-only.
  codeEnc   String?
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  admin     AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
}

enum AdminRole {
  OWNER
  MANAGER
  STAFF
}

// Append-only audit trail of privileged admin actions — same pattern as
// OrderStatusLog/OrderNote. actorName is a SNAPSHOT of the username so the
// log survives an admin rename or deletion. adminId is nullable for
// system-originated entries.
model AdminActivityLog {
  id        Int        @id @default(autoincrement())
  adminId   Int?
  actorName String
  action    String
  detail    String?    @db.Text
  createdAt DateTime   @default(now())
  admin     AdminUser? @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([adminId])
}

// Single-use, short-lived admin password-reset tokens. usedAt marks
// consumption (kept for audit rather than deleted, like LoginToken) so a
// replayed link is rejected even inside the expiry window.
model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  adminId   Int
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  admin     AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
}

// The DB row is the editable source of truth; middleware enforces against a
// mirrored Redis SET (O(1), no DB hit per request). On add/remove, sync both,
// and rebuild the Redis set from this table on boot so a cache flush can't
// silently unblock everyone.
model BlockedIp {
  id        Int      @id @default(autoincrement())
  ip        String   @unique
  reason    String?
  createdAt DateTime @default(now())
}

// Audit log for every outbound mail attempt — sent via the queue, never
// inline with checkout. One row per attempt (including retries), so a
// failure trail is visible even though the worker retries automatically.
model MailLog {
  id        Int          @id @default(autoincrement())
  to        String
  subject   String
  template  String
  status    NotifyStatus @default(PENDING)
  error     String?      @db.Text
  createdAt DateTime     @default(now())

  @@index([status, createdAt])
}

// Same auditing role as MailLog, for SMS sends.
model SmsLog {
  id        Int          @id @default(autoincrement())
  to        String
  template  String
  status    NotifyStatus @default(PENDING)
  error     String?      @db.Text
  createdAt DateTime     @default(now())

  @@index([status, createdAt])
}

enum NotifyStatus {
  PENDING
  SENT
  FAILED
}

// One consignment per order. Webhook updates key on consignmentId + status
// so a duplicate callback (providers retry) is a no-op rather than a
// double-write — see the webhook route for the idempotency check.
model CourierShipment {
  id            Int      @id @default(autoincrement())
  orderId       Int      @unique
  courierName   String
  consignmentId String   @unique
  trackingCode  String?
  courierStatus String
  lastSyncedAt  DateTime @default(now())
  createdAt     DateTime @default(now())
  order         Order    @relation(fields: [orderId], references: [id])

  @@index([consignmentId])
}

// Cached per phone number — also mirrored in Redis (see lib/fraud-cache.ts)
// since fraud lookups cost money/time per call.
model FraudCheckResult {
  id            Int      @id @default(autoincrement())
  phone         String   @unique
  totalOrders   Int      @default(0)
  successOrders Int      @default(0)
  returnOrders  Int      @default(0)
  riskScore     Int
  checkedAt     DateTime @default(now())
}

// Generic encrypted-capable config store. `group` namespaces keys
// (e.g. "smtp", "courier"); secrets are encrypted at rest via lib/crypto.ts
// and flagged with isEncrypted so the reader knows to decrypt.
model Setting {
  id          Int      @id @default(autoincrement())
  group       String
  key         String
  value       String   @db.Text
  isEncrypted Boolean  @default(false)
  updatedAt   DateTime @updatedAt

  @@unique([group, key])
}

enum PageStatus {
  PUBLISHED
  DRAFT
}

// Fixed set of footer/legal/support pages (About Us, Contact Us, Company
// Information, Terms & Conditions, Privacy Policy, Support Center, How to
// Order, Order Tracking, Payment, Shipping). Slugs are seeded once and never
// created/deleted from the admin UI — admins only edit title/content/status.
model Page {
  id              Int        @id @default(autoincrement())
  slug            String     @unique
  title           String
  content         String     @db.Text
  status          PageStatus @default(PUBLISHED)
  // Optional SEO overrides (Phase 2); blank → default from title/content.
  metaTitle       String?
  metaDescription String?    @db.Text
  updatedAt       DateTime   @updatedAt
}

// FAQ entries shown on the FAQ page. Unlike Page, this is a real list the
// admin can add/remove/reorder, since FAQs are naturally many Q&A pairs
// rather than one block of content.
model FaqItem {
  id        Int      @id @default(autoincrement())
  question  String
  answer    String   @db.Text
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

// ─────────────────────────────────────────────────────────────
// Finance — manual operating expenses (OpEx)
// ─────────────────────────────────────────────────────────────

// Fixed / recurring overheads the admin enters by hand — marketing spend,
// hosting, rent, salaries, etc. These are the OpEx items that don't fall out of
// order data automatically. `incurredOn` (not createdAt) drives which month the
// expense lands in on the P&L, so a bill can be back-dated to the month it
// belongs to. `amount` is paisa, like every other money field.
model Expense {
  id          Int             @id @default(autoincrement())
  category    ExpenseCategory @default(OTHER)
  description String
  amount      Int
  incurredOn  DateTime
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([incurredOn])
}

enum ExpenseCategory {
  MARKETING // ads, promotions, influencer spend
  SOFTWARE // hosting, SaaS tools, domains
  RENT // office / warehouse rent
  SALARY // staff wages
  UTILITIES // internet, electricity, phone
  PACKAGING // boxes, tape, polymailers
  OTHER
}

// Ad spend by channel, entered by hand (no ad-platform APIs in v1). Kept SEPARATE
// from Expense: the finance dashboard ties this against ATTRIBUTED delivered-order
// revenue to compute per-channel ROAS and CAC, which needs a channel dimension the
// generic Expense.MARKETING line doesn't carry. `spentOn` (not createdAt) decides
// which month a spend lands in — same back-dating convention as Expense.incurredOn.
// `amount` is paisa, like every money field. Overlaps with the MARKETING expense
// line by design (spend is tracked here for ROAS; whether it also books to the P&L
// as a MARKETING expense is a separate manual entry).
model AdSpend {
  id        Int       @id @default(autoincrement())
  channel   AdChannel @default(FACEBOOK)
  amount    Int // paisa
  spentOn   DateTime // any day in the month the spend belongs to
  note      String?
  createdBy String? // admin username who entered it (audit)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([spentOn])
  @@index([channel, spentOn])
}

// Marketing channels an order can be attributed to, and that spend is booked
// against. ORGANIC/DIRECT is the catch-all for orders with no ad attribution;
// no spend is entered against it, so its ROAS/CAC are not shown.
enum AdChannel {
  FACEBOOK
  GOOGLE
  TIKTOK
  OTHER
}

// Lightweight storefront funnel events, recorded server-side where each action
// already happens (product view, add-to-cart, checkout start, order placed), so
// the admin can see conversion rates in-house instead of only firing pixel
// events outward. Writes are fire-and-forget — never block or fail the
// user-facing action — and blocked-IP / bot traffic is filtered before insert.
//
// sessionId = the anonymous/identified customer id (no new cookie is minted);
// it's coarse by design and used mainly for the per-session/product/day view
// debounce. Rows older than 90 days are pruned by the daily maintenance job.
model FunnelEvent {
  id        Int             @id @default(autoincrement())
  type      FunnelEventType
  sessionId String
  productId Int?
  createdAt DateTime        @default(now())

  // Range scans by (type, createdAt) drive the 30-day funnel aggregation and
  // the 90-day prune; no FK on productId — events must survive product deletes.
  @@index([type, createdAt])
  @@index([createdAt])
}

enum FunnelEventType {
  PRODUCT_VIEW
  ADD_TO_CART
  CHECKOUT_START
  ORDER_PLACED
}

// ─────────────────────────────────────────────────────────────
// Phase 4 — Conversion & Anti-Fraud
// ─────────────────────────────────────────────────────────────

// Discount code. `value` is a whole-number percentage for PERCENT, or a paisa
// amount for FIXED. maxDiscount caps a percent coupon. The discount is
// SNAPSHOTTED onto the Order at checkout, so later edits never rewrite history.
model Coupon {
  id               Int                @id @default(autoincrement())
  code             String             @unique
  type             CouponType
  value            Int
  minOrder         Int                @default(0) // paisa; 0 = no minimum
  maxDiscount      Int? // paisa cap for percent coupons
  usageLimit       Int? // total redemptions across all customers (null = unlimited)
  perCustomerLimit Int? // redemptions per customer (null = unlimited)
  startsAt         DateTime?
  endsAt           DateTime?
  isActive         Boolean            @default(true)
  timesUsed        Int                @default(0)
  // Scope: what the discount applies to. ALL = whole cart (default).
  // CATEGORY = only lines whose product is in categoryId. PRODUCT = only
  // lines for productId. For CATEGORY/PRODUCT the percent/fixed discount is
  // computed against the ELIGIBLE lines' subtotal, not the whole cart.
  appliesTo        CouponScope        @default(ALL)
  categoryId       Int?
  productId        Int?
  category         Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  product          Product?           @relation(fields: [productId], references: [id], onDelete: SetNull)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  redemptions      CouponRedemption[]

  @@index([isActive])
  @@index([categoryId])
  @@index([productId])
}

enum CouponType {
  PERCENT
  FIXED
}

enum CouponScope {
  ALL
  CATEGORY
  PRODUCT
}

// One row per successful coupon use. Enforces per-customer limits (by phone,
// which every order has) and drives the "times used" counter.
model CouponRedemption {
  id            Int      @id @default(autoincrement())
  couponId      Int
  orderId       Int      @unique
  customerId    String?
  customerPhone String
  amount        Int // paisa discount applied
  createdAt     DateTime @default(now())
  coupon        Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([couponId])
  @@index([customerPhone])
}

// A saved cart for an identified customer, used for abandoned-cart recovery.
// One live cart per customerId (upserted). recoveryToken powers the restore
// link; reminderSentAt/recoveredAt drive the delayed job and the report.
model CartSession {
  id             Int       @id @default(autoincrement())
  customerId     String?   @unique
  email          String?
  phone          String?
  items          Json // snapshot of cart lines (productId, variantId, qty, name, price)
  subtotal       Int
  recoveryToken  String    @unique
  reminderSentAt DateTime?
  recoveredAt    DateTime?
  orderedAt      DateTime? // set when this cart's customer places an order (no reminder needed)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([reminderSentAt, orderedAt, updatedAt])
}

// Customer-initiated return request against a delivered order. Feeds an admin
// queue; approving it drives the existing RETURNED order workflow.
model ReturnRequest {
  id         Int          @id @default(autoincrement())
  orderId    Int
  customerId String?
  reason     String       @db.Text
  photoUrl   String?
  status     ReturnStatus @default(PENDING)
  adminNote  String?      @db.Text
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  order      Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([orderId])
}

enum ReturnStatus {
  PENDING
  APPROVED
  REJECTED
}

// A product a customer saved to their wishlist. One row per (customer, product).
model WishlistItem {
  id         Int      @id @default(autoincrement())
  customerId String
  productId  Int
  createdAt  DateTime @default(now())
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId])
  @@index([customerId])
}

// The logged-in customer's live cart, persisted server-side so it follows them
// across devices. One cart per customer. Like the client-side store in
// lib/cart-store.ts this is DISPLAY ONLY — checkout re-verifies price and stock
// inside a transaction; the browser (and this table) are never trusted for what
// gets charged. Guests keep a localStorage-only cart and have no row here.
model CustomerCart {
  id         Int                @id @default(autoincrement())
  customerId String             @unique
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  customer   Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items      CustomerCartItem[]
}

// One line of a persisted cart, identified by (cart, product, variant) — the
// same product in two variants is two lines, mirroring cartLineKey() in
// lib/cart-store.ts. variantId is a plain nullable column (as in WishlistItem /
// StockNotification), null when the product has no variants.
model CustomerCartItem {
  id        Int          @id @default(autoincrement())
  cartId    Int
  productId Int
  variantId Int?
  quantity  Int
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  cart      CustomerCart @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId, variantId])
  @@index([cartId])
}

// Append-only log of add-to-cart events for the profile's cart-history tab.
// Distinct from CustomerCart (the live cart): this records every add, even for
// items later removed, so the history is a faithful trail. Written only for
// logged-in customers.
model CartEvent {
  id         Int      @id @default(autoincrement())
  customerId String
  productId  Int
  variantId  Int?
  quantity   Int
  createdAt  DateTime @default(now())
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([customerId, createdAt])
  @@index([productId])
}

// "Notify me when back in stock" subscription. notifiedAt is set once the
// alert has been queued, so a later restock doesn't re-notify the same person.
model StockNotification {
  id         Int       @id @default(autoincrement())
  productId  Int
  variantId  Int?
  email      String?
  phone      String?
  customerId String?
  notifiedAt DateTime?
  createdAt  DateTime  @default(now())
  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, notifiedAt])
}

// Audit log of MANUAL stock corrections by an admin (received a shipment,
// damaged units, stock-take fix, etc.). Order-driven stock changes go through
// checkout/restock, not here — this is only for hand corrections, so who/when/
// why is recorded. delta is signed (+ added, − removed); newStock snapshots the
// resulting level.
model StockAdjustment {
  id        Int      @id @default(autoincrement())
  productId Int
  variantId Int?
  delta     Int
  newStock  Int
  reason    String
  adminName String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, createdAt])
}

// Newsletter signups from the storefront footer box ("Get ৳150 off…"). Email is
// unique so a re-subscribe is a no-op (see server/newsletter). name is captured
// from the logged-in customer at signup time when available, else left blank.
// customerId is a soft link (the customer id string) for later attribution.
model NewsletterSubscriber {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  name       String?
  customerId String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}
